# ============================================
# BACKEND ENVIRONMENT VARIABLES
# Copia este archivo a .env.local y rellena tus valores
# ============================================

# Stripe (procesamiento de pagos)
STRIPE_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# PayPal (alternativa de pagos)
PAYPAL_ID=xxxxxxxxxxxxx
PAYPAL_SECRET=xxxxxxxxxxxxx

# WhatsApp Business API
WHATSAPP_TOKEN=xxxxxxxxxxxxx
WHATSAPP_WEBHOOK_VERIFY_TOKEN=xxxxxxxxxxxxx
WHATSAPP_BUSINESS_PHONE_ID=xxxxxxxxxxxxx

# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/newzelland

# Email (para notificaciones)
ADMIN_EMAIL=info@newzelland.es
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# Entorno
NODE_ENV=development
PORT=3000
